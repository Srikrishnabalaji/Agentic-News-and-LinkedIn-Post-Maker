# ----- Copy to backend/.env for local dev, or set these in Railway's
#       service Variables tab for production. -----

# Database. Leave unset locally to use SQLite. Railway's Postgres plugin
# injects DATABASE_URL automatically when you attach it.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Gemini (post generation, primary — free tier, no billing needed) ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# --- OpenAI (post generation, secondary fallback — requires billing credits) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (post generation, tertiary fallback — requires billing credits) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Set to true to force the offline mock generator even if a key is present.
USE_MOCK_GENERATOR=false

# --- Email digest (Gmail SMTP) ---
# Use a Google App Password (NOT your normal password). See README.
GMAIL_ADDRESS=quantrixlabs@gmail.com
GMAIL_APP_PASSWORD=
NOTIFICATION_EMAIL=quantrixlabs@gmail.com

# --- Image providers (Openverse + Wikimedia need no key; others are optional) ---
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
# Free at https://pixabay.com/api/docs/ — large royalty-free photo library
PIXABAY_API_KEY=

# --- App wiring ---
# Public URL of the web app (used in the email's "Open editor" button).
FRONTEND_URL=http://localhost:5173
# Secret guarding the optional HTTP cron endpoint /runs/pipeline.
CRON_SECRET=change-me-in-production
POSTS_PER_RUN=5
NOVELTY_WINDOW_DAYS=7
HISTORY_RETENTION_DAYS=14
